{
  "name": "glaux-website",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0 <23"
  },
  "scripts": {
    "dev": "ASTRO_TELEMETRY_DISABLED=1 astro dev",
    "build": "npm run validate:content && ASTRO_TELEMETRY_DISABLED=1 astro build",
    "preview": "ASTRO_TELEMETRY_DISABLED=1 astro preview",
    "validate:content": "ASTRO_TELEMETRY_DISABLED=1 astro sync && node --experimental-strip-types scripts/validate-content.ts",
    "typecheck": "ASTRO_TELEMETRY_DISABLED=1 astro check",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:e2e": "PUBLIC_HUBSPOT_DEMO_FORM_ENABLED=true PUBLIC_HUBSPOT_PORTAL_ID=123456 PUBLIC_HUBSPOT_DEMO_FORM_ID=00000000-0000-4000-8000-000000000000 PUBLIC_HUBSPOT_REGION=na2 npm run build && playwright test"
  },
  "dependencies": {
    "@astrojs/mdx": "7.0.3",
    "@tailwindcss/vite": "4.3.3",
    "astro": "7.1.1",
    "tailwindcss": "4.3.3"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@eslint/js": "9.39.5",
    "@playwright/test": "1.61.1",
    "@types/node": "22.20.1",
    "astro-eslint-parser": "3.0.0",
    "eslint": "9.39.5",
    "eslint-plugin-astro": "1.3.1",
    "prettier": "3.9.5",
    "prettier-plugin-astro": "0.14.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.5",
    "vitest": "4.1.10",
    "yaml": "2.9.0"
  }
}
