---
import { brandAssets } from "../lib/design-system";

type LogoVariant = "lockup" | "mark" | "reversedMark";

interface Props {
  variant?: LogoVariant;
  class?: string;
  priority?: boolean;
  alt?: string;
}

const {
  variant = "lockup",
  class: className = "",
  priority = false,
  alt,
} = Astro.props;
const asset = brandAssets[variant];
---

<img
  src={asset.src}
  width={asset.width}
  height={asset.height}
  alt={alt ?? asset.alt}
  class:list={["brand-logo", `brand-logo--${variant}`, className]}
  loading={priority ? "eager" : "lazy"}
  decoding="async"
/>
