---
import "../styles/global.css";
import BrandLogo from "./BrandLogo.astro";
import Button from "./Button.astro";
import {
  buildAppLoginUrl,
  footerNavigation,
  primaryNavigation,
  productNavigation,
} from "../lib/site";

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  noindex?: boolean;
  og?: {
    title: string;
    description: string;
    url: string;
    type: string;
    image?: string;
    imageAlt?: string;
  };
}

const { title, description, canonicalUrl, noindex = false, og } = Astro.props;
const signInUrl = buildAppLoginUrl();
const currentPath = Astro.url.pathname;
const isProductSection = productNavigation.some(
  (item) => item.href === currentPath,
);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/brand/glaux-mark.svg" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    {og && <meta property="og:type" content={og.type} />}
    {og && <meta property="og:title" content={og.title} />}
    {og && <meta property="og:description" content={og.description} />}
    {og && <meta property="og:url" content={og.url} />}
    {
      og?.image && (
        <>
          <meta property="og:image" content={og.image} />
          <meta property="og:image:alt" content={og.imageAlt} />
        </>
      )
    }
    <title>{title}</title>
  </head>
  <body>
    <div class="page-shell">
      <a class="skip-link" href="#main-content">Skip to main content</a>

      <header class="site-header">
        <a href="/" aria-label="Glaux home" class="brand-home">
          <BrandLogo priority alt="" />
        </a>

        <nav class="site-nav site-nav--desktop" aria-label="Primary">
          <div class="site-nav__pages">
            <details class="nav-dropdown" data-nav-dropdown>
              <summary
                class:list={[
                  "site-nav__link",
                  "nav-dropdown__trigger",
                  { "nav-dropdown__trigger--active": isProductSection },
                ]}
              >
                Product
                <svg
                  aria-hidden="true"
                  viewBox="0 0 12 8"
                  width="12"
                  height="8"
                >
                  <path d="M1 1.5 6 6.5l5-5"></path>
                </svg>
              </summary>
              <div class="nav-dropdown__panel">
                <nav
                  class="nav-dropdown__content"
                  aria-label="Product sections"
                >
                  <a
                    class="nav-dropdown__featured"
                    href={productNavigation[0].href}
                    aria-current={currentPath === productNavigation[0].href
                      ? "page"
                      : undefined}
                  >
                    <strong>{productNavigation[0].label}</strong>
                    <p>{productNavigation[0].description}</p>
                    <span>Explore product</span>
                  </a>
                  <div class="nav-dropdown__links">
                    {
                      productNavigation.slice(1).map((item) => (
                        <a
                          href={item.href}
                          aria-current={
                            currentPath === item.href ? "page" : undefined
                          }
                        >
                          <strong>{item.label}</strong>
                          <p>{item.description}</p>
                        </a>
                      ))
                    }
                  </div>
                </nav>
              </div>
            </details>
            {
              primaryNavigation.map((item) => (
                <a
                  class="site-nav__link"
                  href={item.href}
                  aria-current={currentPath === item.href ? "page" : undefined}
                >
                  {item.label}
                </a>
              ))
            }
          </div>
          <div class="site-nav__actions">
            <a class="site-nav__link" href={signInUrl}> Sign in </a>
            <Button href="/contact/" variant="primary">Book a demo</Button>
          </div>
        </nav>

        <details class="mobile-nav">
          <summary class="mobile-nav__summary" aria-label="Open navigation">
            Menu
          </summary>
          <nav class="mobile-nav__panel" aria-label="Mobile primary">
            <div class="mobile-nav__section">
              <span class="mobile-nav__label">Product</span>
              {
                productNavigation.map((item) => (
                  <a
                    class="site-nav__link"
                    href={item.href}
                    aria-current={
                      currentPath === item.href ? "page" : undefined
                    }
                  >
                    {item.label}
                  </a>
                ))
              }
            </div>
            {
              primaryNavigation.map((item) => (
                <a
                  class="site-nav__link"
                  href={item.href}
                  aria-current={currentPath === item.href ? "page" : undefined}
                >
                  {item.label}
                </a>
              ))
            }
            <a class="site-nav__link" href={signInUrl}>Sign in</a>
            <Button href="/contact/" variant="primary">Book a demo</Button>
          </nav>
        </details>
      </header>

      <main id="main-content" tabindex="-1">
        <slot />
      </main>

      <footer class="site-footer">
        <div class="site-footer__inner">
          <div class="site-footer__brand">
            <BrandLogo alt="Glaux" />
            <p>Useful AI for work. Visible control for the organization.</p>
          </div>
          <nav class="site-footer__nav" aria-label="Footer">
            {
              footerNavigation.map((item) => (
                <a href={item.href}>{item.label}</a>
              ))
            }
            <a href={signInUrl}>Sign in</a>
            <a href="/contact/">Book a demo</a>
          </nav>
        </div>
      </footer>
    </div>

    <script>
      const navigationDropdowns = document.querySelectorAll<HTMLDetailsElement>(
        "[data-nav-dropdown]",
      );

      for (const dropdown of navigationDropdowns) {
        const trigger = dropdown.querySelector<HTMLElement>("summary");

        document.addEventListener("click", (event) => {
          if (dropdown.open && !dropdown.contains(event.target as Node)) {
            dropdown.open = false;
          }
        });

        dropdown.addEventListener("keydown", (event) => {
          if (event.key === "Escape" && dropdown.open) {
            event.preventDefault();
            dropdown.open = false;
            trigger?.focus();
          }
        });
      }
    </script>
  </body>
</html>
