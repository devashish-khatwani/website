---
import SiteLayout from "./SiteLayout.astro";
import { buildPageHeadMetadata } from "../lib/site";

interface Props {
  title: string;
  description: string;
  canonicalPath: string;
  heading: string;
  body: string;
}

const { title, description, canonicalPath, heading, body } = Astro.props;
const pageHead = buildPageHeadMetadata({
  title,
  description,
  canonicalPath,
  og: {
    title,
    description,
    imageAlt: `Monochrome Glaux ${heading} social preview.`,
  },
});
---

<SiteLayout
  title={pageHead.title}
  description={pageHead.description}
  canonicalUrl={pageHead.canonicalUrl}
  noindex
  og={pageHead.og}
>
  <div class="route-main">
    <section class="route-panel" aria-labelledby="route-heading">
      <h1 id="route-heading">{heading}</h1>
      <p>{body}</p>
    </section>
  </div>
</SiteLayout>
