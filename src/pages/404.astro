---
import Button from "../components/Button.astro";
import SiteLayout from "../components/SiteLayout.astro";

Astro.response.status = 404;
---

<SiteLayout
  title="Page not found | Glaux"
  description="The Glaux page you requested may have changed or moved."
  noindex
>
  <div class="route-main">
    <section class="route-panel" aria-labelledby="not-found-heading">
      <p class="not-found-panel__label">404</p>
      <div class="not-found-panel__copy">
        <h1 id="not-found-heading">This page isn’t here.</h1>
        <p>The address may have changed, or the page may have moved.</p>
      </div>
      <div class="not-found-panel__actions" aria-label="Recovery links">
        <Button href="/" variant="primary">Go home</Button>
        <Button href="/product/" variant="ghost">View product</Button>
      </div>
    </section>
  </div>
</SiteLayout>

<style>
  .not-found-panel__label {
    color: var(--color-concrete);
    font-size: var(--text-label);
    font-weight: 650;
    line-height: 1.3;
  }

  .not-found-panel__copy {
    display: grid;
    gap: var(--space-4);
  }

  .not-found-panel__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }
</style>
