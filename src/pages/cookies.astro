---
import SiteLayout from "../components/SiteLayout.astro";
import { buildPageHeadMetadata } from "../lib/site";

const pageHead = buildPageHeadMetadata({
  title: "Cookie policy draft | Glaux",
  description: "Draft Glaux cookie and analytics route pending legal approval.",
  canonicalPath: "/cookies/",
  og: {
    title: "Cookie policy draft | Glaux",
    description:
      "Draft Glaux cookie and analytics route pending legal approval.",
    imageAlt: "Monochrome Glaux cookie policy draft social preview.",
  },
});

const hubspotControls = [
  "The native HubSpot form is intended only for the public contact page.",
  "Preview submissions are intended to stay disabled.",
  "Production form loading is intended only for www.glauxagent.com.",
  "HubSpot is expected to provide native form, CAPTCHA, spam, and CRM processing controls.",
] as const;
---

<SiteLayout
  title={pageHead.title}
  description={pageHead.description}
  canonicalUrl={pageHead.canonicalUrl}
  noindex
  og={pageHead.og}
>
  <div class="product-page">
    <section class="product-hero" aria-labelledby="cookies-heading">
      <div class="product-hero__copy">
        <p class="plain-label">Cookie and analytics draft</p>
        <h1 id="cookies-heading" class="product-title">
          The launch website keeps analytics narrow.
        </h1>
        <p class="product-lede">
          This draft describes the intended public-site cookie and analytics
          boundary. It remains noindex and unpublished until the Project owner
          approves the final privacy, cookie, and form-processing copy.
        </p>
      </div>

      <aside class="surface approval-preview" aria-label="Publication status">
        <div>
          <span class="badge">Draft / noindex</span>
          <h2>Not yet published</h2>
          <p>
            This page does not publish final terms, compliance claims, or data
            commitments. It records the intended launch configuration pending
            Project-owner approval.
          </p>
        </div>
      </aside>
    </section>

    <section class="governance-section" aria-labelledby="analytics-heading">
      <div class="section-heading section-heading--compact">
        <p class="plain-label">Launch analytics</p>
        <h2 id="analytics-heading">
          Cloudflare Web Analytics is the only approved launch analytics.
        </h2>
        <p>
          The intended launch setup uses Cloudflare Web Analytics for aggregate
          public-page traffic and performance. It is not intended to identify a
          visitor, enrich a HubSpot contact, or follow activity into the
          authenticated Glaux app.
        </p>
      </div>

      <div class="surface approval-preview" aria-label="Excluded analytics">
        <div>
          <span class="badge">Outside launch scope</span>
          <h3>Unapproved analytics stay out.</h3>
          <p>
            The launch boundary excludes Google Analytics, Google Tag Manager,
            Plausible, session replay, HubSpot site-wide tracking, custom CTA
            funnels, and custom form funnel tracking.
          </p>
        </div>
      </div>
    </section>

    <section class="admin-section" aria-labelledby="hubspot-heading">
      <div class="section-heading section-heading--compact">
        <p class="plain-label">HubSpot form boundary</p>
        <h2 id="hubspot-heading">
          HubSpot is contact-form infrastructure only.
        </h2>
        <p>
          The public website is intended to use a native externally embedded
          HubSpot form that feeds HubSpot CRM. It is not intended to install
          HubSpot tracking code across the site.
        </p>
      </div>

      <div class="preview-list__items" aria-label="HubSpot controls">
        {
          hubspotControls.map((item) => (
            <article class="preview-row decision-row">
              <div>
                <span class="badge">Control</span>
              </div>
              <p>{item}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="closing-cta" aria-labelledby="approval-heading">
      <h2 id="approval-heading">Publication still needs recorded approval.</h2>
      <p>
        The final cookie and analytics notice must match the configured scripts,
        HubSpot CRM processing boundary, non-marketing contact default,
        processing-only consent text, 365-day inactivity deletion target, and
        deletion request path at privacy@glauxagent.com.
      </p>
    </section>
  </div>
</SiteLayout>
