---
import { getEntry } from "astro:content";
import Button from "../components/Button.astro";
import SiteLayout from "../components/SiteLayout.astro";
import {
  getHubSpotDemoFormAvailability,
  hubSpotFormsRuntimeHostname,
} from "../lib/contact-form";
import { buildPageHeadMetadata } from "../lib/site";

const contactEntry = await getEntry("pages", "contact");

if (!contactEntry) {
  throw new Error("Missing contact page metadata entry.");
}

const pageHead = buildPageHeadMetadata(contactEntry.data);
const hubSpotAvailability = getHubSpotDemoFormAvailability(import.meta.env);
const isHubSpotBuildAvailable = hubSpotAvailability.status === "available";
const heroLede = isHubSpotBuildAvailable
  ? `Share enough context for a useful governance conversation. Online demo requests are available on ${hubSpotFormsRuntimeHostname}; preview, local, and unknown hosts remain closed.`
  : "Share enough context for a useful governance conversation. Online demo requests stay unavailable until the approved HubSpot form, privacy review, and production release controls are ready.";
const requestStatusHeading = isHubSpotBuildAvailable
  ? "Available on production"
  : "Prepared, not open";
const requestStatusCopy = isHubSpotBuildAvailable
  ? `The secure form can load on ${hubSpotFormsRuntimeHostname} for this production build. Preview, local, and unknown hosts remain closed.`
  : "The secure form loads only on the production hostname after the explicit release switch is enabled. Preview, local, and unknown hosts remain closed.";
---

<SiteLayout
  title={pageHead.title}
  description={pageHead.description}
  canonicalUrl={pageHead.canonicalUrl}
  noindex
  og={pageHead.og}
>
  <div class="product-page contact-page">
    <section
      class="product-hero contact-hero"
      aria-labelledby="contact-heading"
    >
      <div class="product-hero__copy">
        <p class="plain-label">Book a demo</p>
        <h1 id="contact-heading" class="product-title">
          Tell us what your team wants AI to help with.
        </h1>
        <p class="product-lede">{heroLede}</p>
        <div class="product-actions" aria-label="Contact page actions">
          <Button href="/product/" variant="ghost">Explore the product</Button>
          <Button href="/security/" variant="ghost">Review security</Button>
        </div>
      </div>

      <aside class="surface company-status-card contact-note">
        <span class="badge">Request status</span>
        <h2>{requestStatusHeading}</h2>
        <p>{requestStatusCopy}</p>
      </aside>
    </section>

    <section class="contact-section" aria-labelledby="demo-form-heading">
      <div class="section-heading section-heading--compact">
        <p class="plain-label">Demo request</p>
        <h2 id="demo-form-heading">Book a demo</h2>
        <p>
          Use the embedded form when it is available. Avoid confidential
          details, credentials, or sensitive architecture information.
        </p>
      </div>

      <div
        class="contact-form surface"
        aria-labelledby="demo-form-heading"
        aria-busy="false"
        data-hubspot-demo-form
        data-state="unavailable"
      >
        <div
          id="contact-form-status"
          class="form-status"
          role="status"
          aria-live="polite"
          tabindex="-1"
        >
          Demo requests are not available online yet.
        </div>

        <div id="hubspot-demo-form-host" class="hubspot-form-host">
          <div class="hubspot-form-skeleton" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
            <span></span>
          </div>
        </div>

        <div class="form-actions">
          <button
            id="contact-form-retry"
            class="button button--ghost"
            type="button"
            hidden
          >
            Try again
          </button>
        </div>
      </div>
    </section>
  </div>
</SiteLayout>

<script>
  import {
    getHubSpotDemoFormAvailability,
    hubSpotFormsEmbedScriptSrc,
    isHubSpotDemoRuntimeHost,
  } from "../lib/contact-form";

  type HubSpotFormEvent = CustomEvent<{ formId?: string }>;
  type HubSpotFormsApi = {
    forms?: {
      create?: (config: {
        region: string;
        portalId: string;
        formId: string;
        target: string;
      }) => void;
    };
  };
  type HubSpotClientState =
    | "unavailable"
    | "loading"
    | "ready"
    | "load-failed"
    | "provider-failed"
    | "success";

  const loadTimeoutMs = 8000;
  const targetSelector = "#hubspot-demo-form-host";
  const iframeTitle = "Glaux demo request HubSpot form";
  const shell = document.querySelector<HTMLElement>("[data-hubspot-demo-form]");
  const host = document.querySelector<HTMLElement>(targetSelector);
  const statusRegion = document.querySelector<HTMLElement>(
    "#contact-form-status",
  );
  const retryButton = document.querySelector<HTMLButtonElement>(
    "#contact-form-retry",
  );
  const availability = getHubSpotDemoFormAvailability(import.meta.env);
  const initialHostMarkup = host?.innerHTML ?? "";
  let currentScript: HTMLScriptElement | undefined;
  let currentState: HubSpotClientState = "unavailable";
  let loadTimer: number | undefined;
  let listenersRegistered = false;
  let lastFocusWasInsideHost = false;

  function setStatus(message: string) {
    if (statusRegion) {
      statusRegion.textContent = message;
    }
  }

  function setState(state: HubSpotClientState, isBusy: boolean) {
    currentState = state;
    if (shell) {
      shell.dataset.state = state;
      shell.setAttribute("aria-busy", String(isBusy));
    }
  }

  function setRetryVisible(isVisible: boolean) {
    if (retryButton) {
      retryButton.hidden = !isVisible;
    }
  }

  function clearLoadTimer() {
    if (loadTimer !== undefined) {
      window.clearTimeout(loadTimer);
      loadTimer = undefined;
    }
  }

  function removeLoaderScript() {
    currentScript?.remove();
    currentScript = undefined;
  }

  function resetHostSkeleton() {
    if (host) {
      host.innerHTML = initialHostMarkup;
    }
  }

  function setIframeTitles() {
    for (const iframe of host?.querySelectorAll("iframe") ?? []) {
      iframe.setAttribute("title", iframeTitle);
    }
  }

  function restoreFocusIfNeeded() {
    if (!lastFocusWasInsideHost || !statusRegion) {
      return;
    }

    const activeElement = document.activeElement;
    if (
      !activeElement ||
      activeElement === document.body ||
      host?.contains(activeElement)
    ) {
      statusRegion.focus({ preventScroll: true });
    }
    lastFocusWasInsideHost = false;
  }

  function eventIsForDemoForm(event: Event): event is HubSpotFormEvent {
    return (
      availability.status === "available" &&
      (event as HubSpotFormEvent).detail?.formId === availability.config.formId
    );
  }

  function canAcceptProviderSubmissionEvent() {
    return currentState === "ready" || currentState === "provider-failed";
  }

  function markLoadFailed() {
    clearLoadTimer();
    removeLoaderScript();
    resetHostSkeleton();
    setState("load-failed", false);
    setStatus(
      "The demo request form could not load. Check browser script blocking and try again.",
    );
    setRetryVisible(true);
  }

  function registerHubSpotEventListeners() {
    if (listenersRegistered) {
      return;
    }
    listenersRegistered = true;

    document.addEventListener("focusin", (event) => {
      lastFocusWasInsideHost =
        event.target instanceof Node && host?.contains(event.target) === true;
    });

    window.addEventListener("hs-form-event:on-ready", (event) => {
      if (!eventIsForDemoForm(event) || currentState !== "loading") {
        return;
      }
      clearLoadTimer();
      setState("ready", false);
      setRetryVisible(false);
      setIframeTitles();
      setStatus("Demo request form is ready.");
    });

    window.addEventListener("hs-form-event:on-submission:success", (event) => {
      if (!eventIsForDemoForm(event) || !canAcceptProviderSubmissionEvent()) {
        return;
      }
      clearLoadTimer();
      setState("success", false);
      setRetryVisible(false);
      setIframeTitles();
      setStatus("Your demo request was received. Glaux will follow up.");
      restoreFocusIfNeeded();
    });

    window.addEventListener("hs-form-event:on-submission:failed", (event) => {
      if (!eventIsForDemoForm(event) || !canAcceptProviderSubmissionEvent()) {
        return;
      }
      clearLoadTimer();
      setState("provider-failed", false);
      setRetryVisible(false);
      setIframeTitles();
      setStatus(
        "The form could not complete the submission. Check the highlighted fields and try again.",
      );
      restoreFocusIfNeeded();
    });
  }

  function createHubSpotForm() {
    if (availability.status !== "available" || currentState !== "loading") {
      return;
    }

    const hbspt = (window as Window & { hbspt?: HubSpotFormsApi }).hbspt;
    const create = hbspt?.forms?.create;

    if (!create) {
      markLoadFailed();
      return;
    }

    try {
      create({
        region: availability.config.region,
        portalId: availability.config.portalId,
        formId: availability.config.formId,
        target: targetSelector,
      });
    } catch {
      markLoadFailed();
    }
  }

  function loadHubSpotForm() {
    if (!shell || !host) {
      return;
    }

    if (
      availability.status !== "available" ||
      !isHubSpotDemoRuntimeHost(window.location.hostname)
    ) {
      clearLoadTimer();
      removeLoaderScript();
      resetHostSkeleton();
      setState("unavailable", false);
      setStatus("Demo requests are not available online yet.");
      setRetryVisible(false);
      return;
    }

    clearLoadTimer();
    removeLoaderScript();
    resetHostSkeleton();
    registerHubSpotEventListeners();
    setState("loading", true);
    setStatus("Loading secure demo request form.");
    setRetryVisible(false);

    const script = document.createElement("script");
    currentScript = script;
    script.src = hubSpotFormsEmbedScriptSrc;
    script.async = true;
    script.onload = () => {
      if (currentScript === script && currentState === "loading") {
        createHubSpotForm();
      }
    };
    script.onerror = () => {
      if (currentScript === script && currentState === "loading") {
        markLoadFailed();
      }
    };
    loadTimer = window.setTimeout(() => {
      if (currentScript === script && currentState === "loading") {
        markLoadFailed();
      }
    }, loadTimeoutMs);
    document.head.append(script);
  }

  retryButton?.addEventListener("click", loadHubSpotForm);
  loadHubSpotForm();
</script>
