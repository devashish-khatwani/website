# Canonical public website origin used for absolute canonical URLs and sitemap
# entries. Keep this as an HTTPS origin only: no path, query, or fragment.
PUBLIC_SITE_ORIGIN=https://www.glauxagent.com

# Authenticated Glaux web app origin used only to build the public "Sign in"
# handoff URL. Keep this as an HTTPS origin only: no path, query, or fragment.
PUBLIC_APP_ORIGIN=https://app.glauxagent.com

# Native HubSpot demo form embed controls. These are public build-time values,
# not secrets. Leave disabled until W-13 approval and HubSpot account setup are
# complete. The runtime still loads only on the exact www.glauxagent.com host.
PUBLIC_HUBSPOT_DEMO_FORM_ENABLED=false
PUBLIC_HUBSPOT_PORTAL_ID=
PUBLIC_HUBSPOT_DEMO_FORM_ID=
PUBLIC_HUBSPOT_REGION=
